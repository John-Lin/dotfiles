{
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "afplay /System/Library/Sounds/Glass.aiff"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bunx -y ccstatusline@latest"
  },
  "extraKnownMarketplaces": {
    "cq": {
      "source": {
        "source": "github",
        "repo": "mozilla-ai/cq"
      }
    }
  },
  "enabledPlugins": {
    "cq@cq": true
  }
}
